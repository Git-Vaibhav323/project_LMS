# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/faculty_cms?schema=public"

# JWT
JWT_SECRET="replace-this-with-a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# CORS - Frontend origin allowed to call this API
CLIENT_ORIGIN="http://localhost:3000"

# File uploads
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=10

# Supabase Storage
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
SUPABASE_BUCKET="faculty-files"
